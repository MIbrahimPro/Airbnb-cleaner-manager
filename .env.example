MONGODB_URI="mongodb+srv://user:password@example.mongodb.net/cleaner-qc"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Primary AI provider.
AI_PROVIDER="openai"
OPENAI_API_KEY="your-openai-api-key"
AI_MODEL_BASE="gpt-5.4-mini"
AI_MODEL_APPEAL="gpt-5.4"

# Optional Ollama fallback. Set AI_PROVIDER="ollama" to use these.
OLLAMA_KEY="your-ollama-cloud-key"
AI_BASE_URL="https://ollama.com/v1"
OLLAMA_MODEL_BASE="gemma3:4b"
OLLAMA_MODEL_APPEAL="llama3.2-vision"
